{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/tauri.conf.schema.json",
  "productName": "Business OS",
  "version": "1.0.0",
  "identifier": "com.businessos.app",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "TAURI_BUILD=1 npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "title": "Business OS — 你的企业数字孪生",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Business OS"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {}
  }
}
